# ── Required ──────────────────────────────────────────────────────────────────
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Models ────────────────────────────────────────────────────────────────────
MODEL=openai/gpt-4o-mini
EMBEDDINGS_MODEL=openai/text-embedding-3-small

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
WEB_CONCURRENCY=4

# ── App identity (sent as OpenRouter headers) ─────────────────────────────────
APP_SITE_URL=http://localhost:8080
APP_TITLE=Fynd AI

# ── Boltic integration ────────────────────────────────────────────────────────
BOLTIC_TOKEN=your_boltic_token_here
BOLTIC_PRODUCTS_TABLE=your_products_table_id_here
BOLTIC_RECS_TABLE=your_recs_table_id_here

# ── RAG tuning ────────────────────────────────────────────────────────────────
RAG_SIMILARITY_THRESHOLD=0.50
RAG_TOP_K=5

# ── Generation defaults ───────────────────────────────────────────────────────
DEFAULT_TEMPERATURE=0.45
DEFAULT_MAX_TOKENS=2048
MAX_INPUT_LENGTH=2000
MAX_HISTORY_CHARS=40000

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:4173

build:
    context: .
    dockerfile: Dockerfile
deploy:
    maxInstances: 1
    minInstances: 1
    port: 8080
    resources:
        cpu: "8"
        memory: 32Gi
environment:
    - name: PORT
      value: "8080"
    - name: OPENROUTER_API_KEY
      value: ${OPENROUTER_API_KEY}
    - name: MODEL
      value: openai/gpt-4o-mini
    - name: EMBEDDINGS_MODEL
      value: openai/text-embedding-3-small
    - name: DEFAULT_TEMPERATURE
      value: "0.45"
    - name: DEFAULT_MAX_TOKENS
      value: "2048"
    - name: MAX_INPUT_LENGTH
      value: "2000"
    - name: MAX_HISTORY_CHARS
      value: "40000"
    - name: APP_SITE_URL
      value: https://your-app.serverless.boltic.app
    - name: APP_TITLE
      value: Fynd AI
    - name: BOLTIC_TOKEN
      value: your-boltic-token-uuid
    - name: BOLTIC_PRODUCTS_TABLE
      value: your-products-table-uuid
    - name: BOLTIC_RECS_TABLE
      value: your-recs-table-uuid
    - name: PYTHONUNBUFFERED
      value: "1"
    - name: WEB_CONCURRENCY
      value: "6"
serverlessConfig:
    Env:
        BOLTIC_TOKEN: your-boltic-token-uuid
        BOLTIC_PRODUCTS_TABLE: your-products-table-uuid
        BOLTIC_RECS_TABLE: your-recs-table-uuid
        EMBEDDINGS_MODEL: openai/text-embedding-3-small
        MODEL: openai/gpt-4o-mini
        OPENROUTER_API_KEY: your-openrouter-api-key
        DEFAULT_TEMPERATURE: "0.45"
        DEFAULT_MAX_TOKENS: "2048"
        WEB_CONCURRENCY: "6"
    PortMap:
        - Protocol: http
          Port: 8080
          Name: http
    Scaling:
        AutoStop: false
        Min: 1
        Max: 1
        MaxIdleTime: 300
    Resources:
        CPU: 8
        MemoryMB: 32768
        MemoryMaxMB: 32768
        DiskMB: 100
    Timeout: 60
service:
    description: Fynd AI — React frontend + FastAPI + OpenRouter
    name: fynd-ai
version: "1"
